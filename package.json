{
  "name": "yuugure",
  "version": "0.1.0",
  "description": "Yuugure - Flash/NML to HTML5 port. Cozy blog + room decoration game.",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && YUUGURE_BASE=/games/yuugure/ vite build",
    "build:local": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "fast-xml-parser": "^4.4.0",
    "gsap": "^3.12.0",
    "pixi.js": "^8.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
